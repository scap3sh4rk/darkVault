<?xml version="1.0" encoding="utf-8"?>
<!--
    Fix: LOW-006 — Explicit network security configuration.
    Blocks all cleartext HTTP traffic and restricts trust to system CAs only.
    All Drive API calls go to https://www.googleapis.com/ — no cleartext needed.
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system"/>
        </trust-anchors>
    </base-config>
</network-security-config>
