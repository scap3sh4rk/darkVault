<?xml version="1.0" encoding="utf-8"?><!--
   Sample backup rules file; uncomment and customize as necessary.
   See https://developer.android.com/guide/topics/data/autobackup
   for details.
   Note: This file is ignored for devices older than API 31
   See https://developer.android.com/about/versions/12/backup-restore
-->
<full-backup-content>
    <!-- Exclude local encrypted cache directories and upload staging.
         vault_cache/ and folder_meta/ contain encrypted ciphertext and metadata;
         encrypt_staging/ contains in-progress encrypted uploads.
         None of these should roam to other devices — the encryption keys do not
         follow the device, so the backed-up ciphertext would be unreadable anyway. -->
    <exclude domain="file" path="vault_cache/"/>
    <exclude domain="file" path="folder_meta/"/>
    <!-- cacheDir/encrypt_staging/ is excluded automatically — cacheDir is never backed up -->
</full-backup-content>