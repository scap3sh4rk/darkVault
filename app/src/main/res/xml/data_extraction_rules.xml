<?xml version="1.0" encoding="utf-8"?>
<!--
    Fix: HIGH-004 — Exclude DataStore files from cloud backup and device-to-device transfer.
    DataStore holds the PBKDF2-derived password hash, salt, biometric IV, and lockout counter.
    Transferring these to another device would enable offline brute-force without device lockout.
    See https://developer.android.com/about/versions/12/backup-restore#xml-changes
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="file" path="datastore/"/>
    </cloud-backup>
    <device-transfer>
        <exclude domain="file" path="datastore/"/>
    </device-transfer>
</data-extraction-rules>
